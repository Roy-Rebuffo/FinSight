# ============================================================
# FinSight — Variables de entorno
# Copia este fichero como .env y rellena los valores reales
# NUNCA subas el .env real al repositorio
# ============================================================

# --- Base de datos PostgreSQL ---
POSTGRES_USER=finsight_user
POSTGRES_PASSWORD=cambia_esta_password_segura
POSTGRES_DB=finsight

# URL completa que usa SQLAlchemy y Alembic para conectarse
# El hostname 'postgres' es el nombre del servicio en docker-compose
DATABASE_URL=postgresql+psycopg2://finsight_user:cambia_esta_password_segura@postgres:5432/finsight

# --- Redis ---
REDIS_URL=redis://redis:6379/0
# El /0 indica que usa la base de datos número 0 de Redis (tiene 16 por defecto)

# --- Seguridad JWT ---
SECRET_KEY=genera-una-clave-aleatoria-de-32-caracteres-minimo
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenAI (para LangGraph en Fase 4) ---
OPENAI_API_KEY=sk-...tu-clave-aqui

# --- Entorno ---
ENVIRONMENT=development