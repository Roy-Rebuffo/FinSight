# ============================================================
# FinSight — Environment variables
# ============================================================

# --- PostgreSQL database ---
POSTGRES_USER=finsight_user
POSTGRES_PASSWORD=change_this_password_to_a_secure_one
POSTGRES_DB=finsight

# Full URL used by SQLAlchemy and Alembic to connect
# The hostname “postgres” is the service name in docker-compose
DATABASE_URL=postgresql+psycopg2://finsight_user:change_this_password_to_a_secure_one@postgres:5432/finsight

# --- Redis ---
REDIS_URL=redis://redis:6379/0
# The /0 indicates that it uses Redis database number 0 (there are 16 by default)

# --- JWT Security ---
SECRET_KEY=generate-a-random-key-of-at-least-32-characters
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- OpenAI (for LangGraph in Phase 4) ---
OPENAI_API_KEY=sk-...your-key-here

# --- Environment ---
ENVIRONMENT=development