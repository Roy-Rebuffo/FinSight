# ============================================================
# FinSight — Environment variables
# ============================================================

# --- PostgreSQL database ---
POSTGRES_USER=finsight_user
POSTGRES_PASSWORD=cambia_esta_password_segura
POSTGRES_DB=finsight

# Full URL used by SQLAlchemy and Alembic to connect
# The hostname “postgres” is the service name in docker-compose
DATABASE_URL=postgresql+psycopg2://finsight_user:cambia_esta_password_segura@postgres:5432/finsight

# --- Redis ---
REDIS_URL=redis://redis:6379/0
# El /0 indica que usa la base de datos número 0 de Redis (tiene 16 por defecto)

# --- JWT Security ---
SECRET_KEY=genera-una-clave-aleatoria-de-32-caracteres-minimo
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
# --- OpenAI (for LangGraph in Phase 4) ---
OPENAI_API_KEY=sk-...tu-clave-aqui

# --- Environment ---
ENVIRONMENT=development