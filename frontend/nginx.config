server {
    listen 80;
    server_name localhost;

    # En Fase 5 aquí serviremos el build de React
    # Por ahora devuelve 200 para confirmar que nginx arranca
    location / {
        return 200 'FinSight frontend placeholder - OK';
        add_header Content-Type text/plain;
    }

    # Proxy hacia la API — todas las rutas /api/* van al backend
    location /api {
        proxy_pass http://api:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}